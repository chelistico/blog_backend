APP_NAME=TechDaily
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://blog-api.local

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=docker_mysql
DB_PORT=3306
DB_DATABASE=techdaily
DB_USERNAME=root
DB_PASSWORD=toor

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

# Sanctum - Desarrollo
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8000,blog-api.local

# CORS - Desarrollo
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://blog-api.local

# Frontend URL for Filament navigation
FRONTEND_URL=http://localhost:5173/
